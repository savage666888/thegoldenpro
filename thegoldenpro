        <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #0a0a0a 0%, #1a0a0a 100%);
            font-family: 'Inter', sans-serif;
            color: #e0e0e0;
            line-height: 1.5;
        }

        /* Warna Premium: Red, Black, Gold */
        :root {
            --black-deep: #000000;
            --black-matte: #0c0c0c;
            --red-glory: #b81c1c;
            --red-bright: #e31c1c;
            --gold-lux: #d4af37;
            --gold-dark: #b8860b;
            --gold-glow: rgba(212, 175, 55, 0.25);
            --white-soft: #f5f5f5;
        }

        .wrap {
            max-width: 1280px;
            margin: 0 auto;
            background: var(--black-deep);
            box-shadow: 0 0 50px rgba(0,0,0,0.8);
        }

        /* Header & Nav */
        .header {
            background: linear-gradient(135deg, #0a0000 0%, #1f1a0a 100%);
            border-bottom: 2px solid var(--gold-lux);
            box-shadow: 0 8px 20px rgba(0,0,0,0.6);
        }
        .logo img {
            max-height: 70px;
            filter: drop-shadow(0 2px 8px rgba(212,175,55,0.4));
        }
        .nav {
            background: #000000d9;
            backdrop-filter: blur(4px);
            border-bottom: 1px solid var(--gold-dark);
        }
        .nav__link {
            color: #f0f0f0;
            font-weight: 600;
            transition: 0.2s;
        }
        .nav__link:hover {
            color: var(--gold-lux);
            text-shadow: 0 0 5px var(--gold-glow);
        }

        /* Buttons Premium */
        .n-columns-2 {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
            margin: 2rem 0;
        }
        .n-columns-2 a {
            position: relative;
            display: block;
            text-align: center;
            padding: 18px 28px;
            font-family: 'Playfair Display', serif;
            font-weight: 800;
            font-size: 1.4rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-decoration: none;
            color: var(--gold-lux);
            background: radial-gradient(circle at 20% 30%, #2c0000, #000000);
            border: 1px solid var(--gold-lux);
            border-radius: 60px;
            box-shadow: 0 4px 20px rgba(184,28,28,0.3), inset 0 1px 0 rgba(255,215,0,0.2);
            transition: all 0.3s ease;
            backdrop-filter: blur(2px);
        }
        .n-columns-2 a:hover {
            transform: translateY(-5px);
            background: var(--red-glory);
            color: #FFD966;
            border-color: #FFD700;
            box-shadow: 0 15px 35px rgba(184,28,28,0.5), 0 0 15px rgba(212,175,55,0.8);
            text-shadow: 0 0 8px rgba(0,0,0,0.5);
        }
        .n-columns-2 a:active {
            transform: translateY(0);
        }

        /* Article Card */
        .blog-card-flat {
            background: #0f0f0f;
            border-radius: 24px;
            padding: 24px;
            border: 1px solid #2a2a2a;
            box-shadow: 0 20px 35px -15px black;
        }
        .cover-photo img {
            border-radius: 18px;
            border: 1px solid var(--gold-dark);
            box-shadow: 0 0 0 2px #2a2a2a, 0 0 0 4px var(--gold-lux);
        }
        .article-box {
            background: #0a0a0a;
            border-left: 5px solid var(--red-glory);
            padding: 25px 30px;
            border-radius: 20px;
            margin-top: 30px;
        }
        .article-box p {
            font-size: 1.05rem;
            line-height: 1.7;
            color: #eaeaea;
            font-weight: 500;
        }
        .article-box a {
            color: var(--gold-lux);
            text-decoration: none;
            font-weight: 700;
            border-bottom: 1px dashed var(--gold-dark);
        }
        .article-box a:hover {
            color: var(--red-bright);
        }

        /* Most Popular Sidebar */
        .most {
            background: #0c0c0c;
            border-radius: 20px;
            border: 1px solid #2c2c2c;
            overflow: hidden;
        }
        .title__content {
            font-family: 'Playfair Display', serif;
            color: var(--gold-lux);
            font-size: 1.6rem;
            border-left: 5px solid var(--red-glory);
            padding-left: 15px;
            margin-bottom: 20px;
        }
        .most__list {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            padding: 14px 18px;
            border-bottom: 1px solid #2a2a2a;
            transition: 0.2s;
        }
        .most__list:hover {
            background: #1a1a1a;
        }
        .most__countmost__count {
            background: linear-gradient(135deg, #b81c1c, #7a0e0e);
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--gold-lux);
            box-shadow: 0 0 8px rgba(212,175,55,0.5);
        }
        .most__title {
            font-weight: 700;
            font-size: 0.95rem;
            color: #f0f0f0;
            line-height: 1.4;
        }
        .most__link {
            text-decoration: none;
            flex: 1;
        }
        .most__link:hover .most__title {
            color: var(--gold-lux);
            text-decoration: underline;
        }

        /* Footer Redesign */
        .footerMain {
            background: #020202;
            border-top: 3px solid var(--gold-lux);
            margin-top: 50px;
            padding: 40px 20px 20px;
        }
        .footerLogo img {
            max-width: 200px;
            filter: brightness(1.1) drop-shadow(0 2px 4px rgba(212,175,55,0.5));
        }
        .footerSosmed-link .iconSos {
            background: #1f1f1f;
            border-radius: 50%;
            width: 38px;
            height: 38px;
            display: inline-block;
            transition: 0.2s;
            border: 1px solid var(--gold-dark);
        }
        .footerSosmed-link:hover .iconSos {
            background: var(--red-glory);
            border-color: var(--gold-lux);
            transform: scale(1.05);
        }
        .footerNewsletter-cta a {
            background: linear-gradient(95deg, #b81c1c, #8b0000);
            color: var(--gold-lux);
            font-weight: 800;
            padding: 12px 28px;
            border-radius: 60px;
            border: 1px solid #d4af37;
            transition: all 0.3s;
        }
        .footerNewsletter-cta a:hover {
            background: var(--gold-lux);
            color: #000;
            border-color: #b81c1c;
            box-shadow: 0 0 15px rgba(212,175,55,0.8);
        }
        .footerMenu-link {
            color: #bbb;
            transition: 0.2s;
        }
        .footerMenu-link:hover {
            color: var(--gold-lux);
        }
        .footerCopyright {
            text-align: center;
            padding-top: 30px;
            border-top: 1px solid #2c2c2c;
            margin-top: 20px;
            color: #aaa;
            font-size: 0.85rem;
        }
        /* Read article styling */
        .read__title {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--gold-lux);
            text-shadow: 2px 2px 0 #5a1a1a;
            margin: 20px 0;
        }
        .breadcrumb a, .read__time a {
            color: var(--gold-dark);
        }
        button, .button-default {
            background: transparent;
            border: none;
        }
        /* Responsive */
        @media (max-width: 768px) {
            .n-columns-2 { gap: 1rem; }
            .n-columns-2 a { font-size: 1rem; padding: 12px 16px; }
            .read__title { font-size: 1.6rem; }
        }
        /* Gold gradient accents */
        h1, h2, h3 {
            font-family: 'Playfair Display', serif;
        }
        hr {
            border-color: var(--gold-dark);
        }
        ::selection {
            background: var(--gold-lux);
            color: black;
